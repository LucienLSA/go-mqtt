{
  "openapi": "3.0.3",
  "info": {
    "title": "go-mqtt API",
    "version": "1.2.0",
    "description": "与当前代码实现对齐的接口文档（含 JWT 鉴权、RBAC、命令超时与重试字段）。"
  },
  "servers": [
    {
      "url": "http://localhost:8080"
    }
  ],
  "tags": [
    { "name": "Health" },
    { "name": "Auth" },
    { "name": "Device" },
    { "name": "EMQX" }
  ],
  "paths": {
    "/ping": {
      "get": {
        "tags": ["Health"],
        "summary": "健康检查",
        "responses": {
          "200": {
            "description": "ok",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PingEnvelope" }
              }
            }
          }
        }
      }
    },
    "/api/v1/auth/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "登录获取 JWT",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/LoginRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "登录成功",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/LoginEnvelope" }
              }
            }
          },
          "401": {
            "description": "用户名或密码错误",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/BaseEnvelope" }
              }
            }
          }
        }
      }
    },
    "/api/v1/auth/me": {
      "get": {
        "tags": ["Auth"],
        "summary": "获取当前登录用户信息",
        "security": [
          { "bearerAuth": [] }
        ],
        "responses": {
          "200": {
            "description": "ok",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MeEnvelope" }
              }
            }
          },
          "401": {
            "description": "未登录或 token 无效",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/BaseEnvelope" }
              }
            }
          }
        }
      }
    },
    "/api/v1/device": {
      "get": {
        "tags": ["Device"],
        "summary": "设备列表",
        "description": "RBAC: admin/operator/viewer",
        "x-roles": ["admin", "operator", "viewer"],
        "security": [
          { "bearerAuth": [] }
        ],
        "responses": {
          "200": {
            "description": "ok",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DeviceListEnvelope" }
              }
            }
          },
          "401": {
            "description": "未登录或 token 无效",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/BaseEnvelope" }
              }
            }
          },
          "403": {
            "description": "无权限",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/BaseEnvelope" }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Device"],
        "summary": "创建设备",
        "description": "RBAC: admin",
        "x-roles": ["admin"],
        "security": [
          { "bearerAuth": [] }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateDeviceRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "ok",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DeviceEnvelope" }
              }
            }
          },
          "401": {
            "description": "未登录或 token 无效",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/BaseEnvelope" }
              }
            }
          },
          "403": {
            "description": "无权限",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/BaseEnvelope" }
              }
            }
          }
        }
      }
    },
    "/api/v1/device/{id}": {
      "get": {
        "tags": ["Device"],
        "summary": "设备详情",
        "description": "RBAC: admin/operator/viewer",
        "x-roles": ["admin", "operator", "viewer"],
        "security": [
          { "bearerAuth": [] }
        ],
        "parameters": [{ "$ref": "#/components/parameters/DeviceId" }],
        "responses": {
          "200": {
            "description": "ok",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DeviceEnvelope" }
              }
            }
          },
          "401": {
            "description": "未登录或 token 无效",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/BaseEnvelope" }
              }
            }
          },
          "403": {
            "description": "无权限",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/BaseEnvelope" }
              }
            }
          }
        }
      },
      "put": {
        "tags": ["Device"],
        "summary": "更新设备",
        "description": "RBAC: admin",
        "x-roles": ["admin"],
        "security": [
          { "bearerAuth": [] }
        ],
        "parameters": [{ "$ref": "#/components/parameters/DeviceId" }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdateDeviceRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "ok",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DeviceEnvelope" }
              }
            }
          },
          "401": {
            "description": "未登录或 token 无效",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/BaseEnvelope" }
              }
            }
          },
          "403": {
            "description": "无权限",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/BaseEnvelope" }
              }
            }
          }
        }
      },
      "delete": {
        "tags": ["Device"],
        "summary": "删除设备",
        "description": "RBAC: admin",
        "x-roles": ["admin"],
        "security": [
          { "bearerAuth": [] }
        ],
        "parameters": [{ "$ref": "#/components/parameters/DeviceId" }],
        "responses": {
          "200": {
            "description": "ok",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/BaseEnvelope" }
              }
            }
          },
          "401": {
            "description": "未登录或 token 无效",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/BaseEnvelope" }
              }
            }
          },
          "403": {
            "description": "无权限",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/BaseEnvelope" }
              }
            }
          }
        }
      }
    },
    "/api/v1/device/{id}/control": {
      "post": {
        "tags": ["Device"],
        "summary": "下发控制",
        "description": "RBAC: admin/operator。响应中返回 timeout_at 和 max_retry。",
        "x-roles": ["admin", "operator"],
        "security": [
          { "bearerAuth": [] }
        ],
        "parameters": [{ "$ref": "#/components/parameters/DeviceId" }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ControlRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "ok",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ControlEnvelope" }
              }
            }
          },
          "401": {
            "description": "未登录或 token 无效",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/BaseEnvelope" }
              }
            }
          },
          "403": {
            "description": "无权限",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/BaseEnvelope" }
              }
            }
          }
        }
      }
    },
    "/api/v1/device/{id}/command": {
      "get": {
        "tags": ["Device"],
        "summary": "命令历史",
        "description": "RBAC: admin/operator/viewer",
        "x-roles": ["admin", "operator", "viewer"],
        "security": [
          { "bearerAuth": [] }
        ],
        "parameters": [
          { "$ref": "#/components/parameters/DeviceId" },
          {
            "name": "limit",
            "in": "query",
            "schema": { "type": "integer", "default": 50 }
          }
        ],
        "responses": {
          "200": {
            "description": "ok",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CommandListEnvelope" }
              }
            }
          },
          "401": {
            "description": "未登录或 token 无效",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/BaseEnvelope" }
              }
            }
          },
          "403": {
            "description": "无权限",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/BaseEnvelope" }
              }
            }
          }
        }
      }
    },
    "/api/v1/emqx/auth": {
      "post": {
        "tags": ["EMQX"],
        "summary": "EMQX HTTP 认证",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/EMQXAuthRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "allow or deny",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/EMQXAuthResponse" }
              }
            }
          }
        }
      }
    },
    "/api/v1/emqx/webhook": {
      "post": {
        "tags": ["EMQX"],
        "summary": "EMQX 连接事件回调",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/EMQXWebhookRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "ok",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/BaseEnvelope" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "parameters": {
      "DeviceId": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": { "type": "integer", "format": "int64" }
      }
    },
    "schemas": {
      "BaseEnvelope": {
        "type": "object",
        "properties": {
          "code": { "type": "integer" },
          "message": { "type": "string" },
          "data": {}
        },
        "required": ["code", "message", "data"]
      },
      "PingEnvelope": {
        "allOf": [{ "$ref": "#/components/schemas/BaseEnvelope" }]
      },
      "LoginRequest": {
        "type": "object",
        "required": ["username", "password"],
        "properties": {
          "username": { "type": "string", "example": "admin" },
          "password": { "type": "string", "example": "admin123" }
        }
      },
      "LoginData": {
        "type": "object",
        "properties": {
          "token": { "type": "string" },
          "role": { "type": "string", "enum": ["admin", "operator", "viewer"] },
          "expires_at": { "type": "integer", "format": "int64" }
        }
      },
      "LoginEnvelope": {
        "allOf": [{ "$ref": "#/components/schemas/BaseEnvelope" }]
      },
      "MeData": {
        "type": "object",
        "properties": {
          "username": { "type": "string" },
          "role": { "type": "string", "enum": ["admin", "operator", "viewer"] }
        }
      },
      "MeEnvelope": {
        "allOf": [{ "$ref": "#/components/schemas/BaseEnvelope" }]
      },
      "Device": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "device_id": { "type": "string" },
          "name": { "type": "string" },
          "group_id": { "type": "integer" },
          "status": { "type": "integer", "description": "0-离线,1-在线" },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "CommandLog": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "device_id": { "type": "string" },
          "trace_id": { "type": "string" },
          "topic": { "type": "string" },
          "payload": { "type": "string" },
          "command": { "type": "string" },
          "result": { "type": "string" },
          "status": { "type": "integer", "description": "0-pending,1-success,2-failed/timeout" },
          "retry_count": { "type": "integer" },
          "max_retry": { "type": "integer" },
          "timeout_at": { "type": "integer", "format": "int64" },
          "next_retry_at": { "type": "integer", "format": "int64" },
          "done_at": { "type": "integer", "format": "int64" },
          "message": { "type": "string" },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "CreateDeviceRequest": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "group_id": { "type": "integer" }
        }
      },
      "UpdateDeviceRequest": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "group_id": { "type": "integer" }
        }
      },
      "ControlRequest": {
        "type": "object",
        "required": ["cmd"],
        "properties": {
          "cmd": { "type": "string" },
          "param": {}
        }
      },
      "ControlData": {
        "type": "object",
        "properties": {
          "device_id": { "type": "string" },
          "trace_id": { "type": "string" },
          "topic": { "type": "string" },
          "timeout_at": { "type": "integer", "format": "int64" },
          "max_retry": { "type": "integer" }
        }
      },
      "DeviceEnvelope": {
        "allOf": [{ "$ref": "#/components/schemas/BaseEnvelope" }]
      },
      "DeviceListEnvelope": {
        "allOf": [{ "$ref": "#/components/schemas/BaseEnvelope" }]
      },
      "ControlEnvelope": {
        "allOf": [{ "$ref": "#/components/schemas/BaseEnvelope" }]
      },
      "CommandListEnvelope": {
        "allOf": [{ "$ref": "#/components/schemas/BaseEnvelope" }]
      },
      "EMQXAuthRequest": {
        "type": "object",
        "properties": {
          "username": { "type": "string" },
          "password": { "type": "string" },
          "clientid": { "type": "string" }
        }
      },
      "EMQXAuthResponse": {
        "type": "object",
        "properties": {
          "result": { "type": "string", "enum": ["allow", "deny"] },
          "is_superuser": { "type": "boolean" }
        }
      },
      "EMQXWebhookRequest": {
        "type": "object",
        "properties": {
          "event": { "type": "string" },
          "action": { "type": "string" },
          "username": { "type": "string" },
          "clientid": { "type": "string" }
        }
      }
    }
  }
}
